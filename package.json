{
  "name": "ztools-ui",
  "version": "0.1.1",
  "description": "Vue 3 UI component library for ZTools plugins",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style": {
      "types": "./dist/style.d.ts",
      "import": "./dist/style.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "docs:dev": "vitepress dev site --port 5180 --open",
    "docs:build": "vitepress build site",
    "docs:preview": "vitepress preview site --port 5181",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@vueuse/core": "^12.7.0",
    "marked": "^15.0.7"
  },
  "peerDependencies": {
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify/utils": "^2.3.0",
    "@types/node": "^25.6.0",
    "@unocss/preset-icons": "^0.65.4",
    "@unocss/transformer-directives": "^0.65.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "highlight.js": "^11.11.1",
    "less": "^4.2.0",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.3.0",
    "unocss": "^0.65.4",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.0.0"
  }
}
