{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "types": ["vite/client", "node"],
    "paths": {
      "ztools-ui-lib": ["./index.ts"],
      "ztools-ui-components/*": ["./components/*"],
      "ztools-ui-composables/*": ["./composables/*"],
      "ztools-ui-utils/*": ["./utils/*"],
      "ztools-ui-assets/*": ["./assets/*"]
    }
  },
  "include": [
    "env.d.ts",
    "index.ts",
    "plugin.ts",
    "resolver.ts",
    "style.ts",
    "vite.config.ts",
    "vite.docs.config.ts",
    "uno.config.ts",
    "assets/**/*.ts",
    "components/**/*.ts",
    "components/**/*.vue",
    "composables/**/*.ts",
    "utils/**/*.ts",
    "site/**/*.ts",
    "site/**/*.vue"
  ],
  "exclude": ["utils/message.ts"]
}
